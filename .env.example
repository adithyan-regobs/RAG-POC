# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# Qdrant (Cloud)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=rag_documents
QDRANT_VECTOR_SIZE=1536

# Retrieval
TOP_K_VECTOR=20
TOP_K_BM25=20
TOP_K_RERANK=10
RRF_K=60
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2

# Query expansion
NUM_QUERY_VARIATIONS=4

# Metadata processing (comma-separated)
MIN_TEXT_LENGTH=50
BOOST_LAW_AREAS=family
BOOST_DOCUMENT_TYPES=judgment
BOOST_VALUE=0.15

# Context assembly
CONTEXT_TOKEN_BUDGET=4000

# Indexing
EMBED_BATCH_SIZE=100
UPSERT_BATCH_SIZE=256
BM25_INDEX_PATH=data/bm25_corpus.pkl
